default_platform(:ios)

# -----------------------------------------------------------------------------
# CarQuiz — fastlane
#
# Auth model:
#   All Apple interactions go through the App Store Connect API key (JWT).
#   Required env vars:
#     ASC_API_KEY_ID       — 10-char key identifier
#     ASC_API_ISSUER_ID    — UUID of the issuer (team-wide)
#     ASC_API_KEY_CONTENT  — contents of the .p8 file (entire text incl. BEGIN/END)
#
#   On CI these come from GitHub Actions Secrets. Locally, create `.env.secret`
#   in this directory (gitignored) or export them in your shell.
#
# Cert storage:
#   `match` pulls encrypted certs + profiles from the MATCH_GIT_URL repo, decrypts
#   with MATCH_PASSWORD, installs into a temporary keychain named by
#   MATCH_KEYCHAIN_NAME. On CI the keychain is created + destroyed inside the
#   workflow — nothing persists between runs.
# -----------------------------------------------------------------------------

platform :ios do
  # Local env loading:
  #   fastlane natively auto-loads `fastlane/.env` and `fastlane/.env.default`.
  #   Create `fastlane/.env` from `.env.example` for local runs. The file is
  #   gitignored. CI does not rely on this — it uses GitHub Secrets directly.

  desc "Build a release IPA and upload to TestFlight."
  lane :beta do
    ensure_env_vars(
      env_vars: %w[
        ASC_API_KEY_ID
        ASC_API_ISSUER_ID
        ASC_API_KEY_CONTENT
        MATCH_GIT_URL
        MATCH_PASSWORD
      ]
    )

    api_key = app_store_connect_api_key(
      key_id: ENV["ASC_API_KEY_ID"],
      issuer_id: ENV["ASC_API_ISSUER_ID"],
      key_content: ENV["ASC_API_KEY_CONTENT"],
      is_key_content_base64: ENV["ASC_API_KEY_CONTENT_IS_BASE64"] == "true",
      in_house: false
    )

    # Sync distribution cert + provisioning profile from the encrypted git repo.
    # readonly on CI prevents the key from accidentally regenerating shared certs,
    # which would invalidate existing installations.
    match(
      type: "appstore",
      api_key: api_key,
      readonly: true
    )

    # Xcode 16+ installs provisioning profiles under ~/Library/Developer/Xcode/UserData.
    # xcodebuild's manual-signing lookup on CI still consults the legacy path, so
    # mirror the freshly installed profiles to avoid "No profile matching ..." errors.
    require "fileutils"
    legacy_dir = File.expand_path("~/Library/MobileDevice/Provisioning Profiles")
    new_dir = File.expand_path("~/Library/Developer/Xcode/UserData/Provisioning Profiles")
    FileUtils.mkdir_p(legacy_dir)
    Dir.glob(File.join(new_dir, "*.mobileprovision")).each { |f| FileUtils.cp(f, legacy_dir) }

    # Diagnostic: list every installed profile with its embedded Name + TeamIdentifier
    # so we can see exactly what xcodebuild's manual-signing lookup is searching against.
    UI.message("=== Installed provisioning profiles ===")
    Dir.glob(File.join(new_dir, "*.mobileprovision")).each do |f|
      plist = `security cms -D -i "#{f}" 2>/dev/null`
      name = plist[/<key>Name<\/key>\s*<string>([^<]+)<\/string>/, 1]
      team = plist[/<key>TeamIdentifier<\/key>\s*<array>\s*<string>([^<]+)<\/string>/, 1]
      uuid = plist[/<key>UUID<\/key>\s*<string>([^<]+)<\/string>/, 1]
      UI.message("  #{File.basename(f)}: Name=#{name.inspect}, Team=#{team.inspect}, UUID=#{uuid}")
    end
    UI.message("=======================================")

    # Auto-bump build number relative to what's already in TestFlight, so we never
    # collide with an existing build.
    next_build = latest_testflight_build_number(
      api_key: api_key,
      app_identifier: "com.missinghue.hangs",
      initial_build_number: 0
    ) + 1

    increment_build_number(
      xcodeproj: "CarQuiz.xcodeproj",
      build_number: next_build
    )

    build_app(
      export_options: {
        method: "app-store",
        provisioningProfiles: {
          "com.missinghue.hangs" => "match AppStore com.missinghue.hangs"
        },
        signingStyle: "manual",
        teamID: "J47232U5B5"
      },
      xcargs: "-allowProvisioningUpdates"
    )

    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true,
      distribute_external: false,
      skip_submission: true
    )

    UI.success("Uploaded build #{next_build} to TestFlight.")
  end

  desc "Dry-run: verify fastlane config + match access without uploading."
  lane :verify_setup do
    ensure_env_vars(
      env_vars: %w[ASC_API_KEY_ID ASC_API_ISSUER_ID ASC_API_KEY_CONTENT MATCH_GIT_URL MATCH_PASSWORD]
    )

    api_key = app_store_connect_api_key(
      key_id: ENV["ASC_API_KEY_ID"],
      issuer_id: ENV["ASC_API_ISSUER_ID"],
      key_content: ENV["ASC_API_KEY_CONTENT"],
      is_key_content_base64: ENV["ASC_API_KEY_CONTENT_IS_BASE64"] == "true"
    )

    match(type: "appstore", api_key: api_key, readonly: true)
    UI.success("Match read OK. Cert + profile installed in keychain.")
  end

  # ---------------------------------------------------------------------------
  # One-time bootstrap lane — run LOCALLY (not on CI) to create the initial
  # distribution certificate and App Store provisioning profile and push them
  # encrypted into the certs repo. Requires ADMIN or APP MANAGER API key role.
  #
  # Usage:
  #   cd apps/ios-app/CarQuiz
  #   bundle exec fastlane ios bootstrap_certs
  # ---------------------------------------------------------------------------
  desc "One-time: create distribution cert + profile and push to certs repo."
  lane :bootstrap_certs do
    UI.important("This will create a NEW distribution certificate if none exists.")
    UI.important("Run this ONCE per app. Running it again with force=true will invalidate existing certs.")

    ensure_env_vars(
      env_vars: %w[ASC_API_KEY_ID ASC_API_ISSUER_ID ASC_API_KEY_CONTENT MATCH_GIT_URL MATCH_PASSWORD]
    )

    api_key = app_store_connect_api_key(
      key_id: ENV["ASC_API_KEY_ID"],
      issuer_id: ENV["ASC_API_ISSUER_ID"],
      key_content: ENV["ASC_API_KEY_CONTENT"]
    )

    # NOT readonly — this run generates the cert + profile if missing.
    match(
      type: "appstore",
      api_key: api_key,
      readonly: false
    )

    UI.success("Cert + profile created and pushed (encrypted) to #{ENV['MATCH_GIT_URL']}.")
  end

  # ---------------------------------------------------------------------------
  # Destructive — revokes ALL certs/profiles for this app. Only use if certs
  # have leaked or you want a clean slate. Requires confirmation.
  # ---------------------------------------------------------------------------
  desc "DESTRUCTIVE: revoke all distribution certs and profiles for this app."
  lane :nuke_certs do
    UI.user_error!("Refusing to run nuke_certs on CI.") if ENV["CI"]

    confirm = UI.input("Type 'NUKE' to confirm revocation:")
    UI.user_error!("Aborted.") unless confirm == "NUKE"

    api_key = app_store_connect_api_key(
      key_id: ENV["ASC_API_KEY_ID"],
      issuer_id: ENV["ASC_API_ISSUER_ID"],
      key_content: ENV["ASC_API_KEY_CONTENT"]
    )

    match_nuke(type: "distribution", api_key: api_key)
  end
end
