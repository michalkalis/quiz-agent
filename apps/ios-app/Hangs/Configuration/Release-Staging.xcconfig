//
// Release-Staging.xcconfig
// Composition for the Release-Staging build configuration (TestFlight — staging API).
// TestFlight = staging (#101): the fastlane `beta` lane pins this configuration so
// sandbox purchases never touch prod data.
//

#include "Release.xcconfig"
#include "Staging.xcconfig"

// MARK: - Signing — driven by fastlane match
// Same bundle id as Prod, so the identical "match AppStore" profile applies.
CODE_SIGN_STYLE = Manual
DEVELOPMENT_TEAM = KAGWHPZZFQ
CODE_SIGN_IDENTITY = Apple Distribution
PROVISIONING_PROFILE_SPECIFIER = match AppStore $(PRODUCT_BUNDLE_IDENTIFIER)
