//
// Prod.xcconfig
// CarQuiz
//
// Configuration for production environment
//

#include "Shared.xcconfig"

// MARK: - Environment
ENVIRONMENT_NAME = Production

// MARK: - API Configuration
API_BASE_URL = https:/$()/quiz-agent-api.fly.dev

// MARK: - Sentry
// `$()` escape breaks the `//` token so xcconfig doesn't treat the rest of the line as a comment.
SENTRY_DSN = https:/$()/c5440340d41535b4862af9385d9bc38c@o4511195958738944.ingest.de.sentry.io/4511196118188112

// MARK: - Bundle Identifier
PRODUCT_BUNDLE_IDENTIFIER = $(BUNDLE_ID_BASE)

// MARK: - App Display Name
PRODUCT_NAME = $(APP_DISPLAY_NAME)

// MARK: - Release Settings
ENABLE_TESTABILITY = NO
GCC_OPTIMIZATION_LEVEL = s
SWIFT_OPTIMIZATION_LEVEL = -O
SWIFT_COMPILATION_MODE = wholemodule

// MARK: - Code Signing (Manual — driven by fastlane match)
// Override Shared.xcconfig's Automatic style. Match installs a provisioning
// profile named "match AppStore <bundle-id>" into the build keychain.
CODE_SIGN_STYLE = Manual
CODE_SIGN_IDENTITY = Apple Distribution
PROVISIONING_PROFILE_SPECIFIER = match AppStore $(PRODUCT_BUNDLE_IDENTIFIER)
