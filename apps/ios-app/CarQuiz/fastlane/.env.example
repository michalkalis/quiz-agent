# Copy to `.env` (gitignored, auto-loaded by fastlane) for local runs:
#   cp .env.example .env
# On CI these come from GitHub Actions Secrets — do NOT commit real values.

# --- App Store Connect API key ---
# Create at: https://appstoreconnect.apple.com/access/integrations/api
# Role: App Manager (sufficient for certs + TestFlight upload)
ASC_API_KEY_ID=XXXXXXXXXX
ASC_API_ISSUER_ID=00000000-0000-0000-0000-000000000000
# Paste the full .p8 contents, including BEGIN/END lines. Multi-line is fine inside quotes.
ASC_API_KEY_CONTENT="-----BEGIN PRIVATE KEY-----
...
-----END PRIVATE KEY-----"

# --- Match (encrypted cert storage) ---
MATCH_GIT_URL=git@github.com:YOUR_USERNAME/carquiz-certs.git
# Generate with: openssl rand -base64 32
MATCH_PASSWORD=replace-with-30-plus-random-chars
# Set to "false" locally to allow cert generation on first bootstrap run.
MATCH_READONLY=true
