//
// Shared.xcconfig
// CarQuiz
//
// Shared build settings for all environments
//

// MARK: - App Information
APP_NAME = CarQuiz
APP_DISPLAY_NAME = CarQuiz

// MARK: - Bundle Identifier Base
// Environment-specific configs will append a suffix to this
BUNDLE_ID_BASE = com.missinghue.hangs

// MARK: - Info.plist Configuration
INFOPLIST_FILE = CarQuiz/Info.plist
GENERATE_INFOPLIST_FILE = NO

// MARK: - API Configuration
API_VERSION = /api/v1

// MARK: - Code Signing (override in environment-specific configs if needed)
CODE_SIGN_STYLE = Automatic
DEVELOPMENT_TEAM = $(inherited)

// MARK: - Swift Settings
SWIFT_VERSION = 6.0
SWIFT_STRICT_CONCURRENCY = complete

// MARK: - Other Settings
TARGETED_DEVICE_FAMILY = 1
IPHONEOS_DEPLOYMENT_TARGET = 18.0

// MARK: - Asset Catalog
// App Store validation requires CFBundleIconName, which xcodebuild only injects
// when ASSETCATALOG_COMPILER_APPICON_NAME points at a real asset set.
ASSETCATALOG_COMPILER_APPICON_NAME = AppIcon
ASSETCATALOG_COMPILER_GLOBAL_ACCENT_COLOR_NAME = AccentColor
