#!/usr/bin/env bash
# Pre-commit hook: mirror the Backend CI "Lint Backend Code" job locally so
# formatting failures are caught before push, not after a red CI email.
#
# Enable once per clone:  git config core.hooksPath .githooks
# Skip a single commit:   git commit --no-verify

set -euo pipefail

# Only run when backend Python is staged — keeps non-backend commits fast.
staged=$(git diff --cached --name-only --diff-filter=ACM \
  -- 'apps/quiz-agent/**/*.py' 'packages/shared/**/*.py')
if [ -z "$staged" ]; then
  exit 0
fi

run_ruff() {
  if command -v ruff >/dev/null 2>&1; then
    ruff "$@"
  else
    uvx ruff "$@"
  fi
}

echo "pre-commit: ruff check + format on apps/quiz-agent/ packages/shared/"
if ! run_ruff check apps/quiz-agent/ packages/shared/; then
  echo "✗ ruff check failed — fix lint errors above, then re-commit." >&2
  exit 1
fi
if ! run_ruff format --check apps/quiz-agent/ packages/shared/; then
  echo "✗ ruff format check failed — run: uvx ruff format apps/quiz-agent/ packages/shared/" >&2
  exit 1
fi
echo "✓ ruff clean"
