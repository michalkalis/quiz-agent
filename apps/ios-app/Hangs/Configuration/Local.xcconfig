//
// Local.xcconfig
// Environment-only settings for local development (API → localhost).
// Include Shared here so any xcconfig that wants just Local can pull the base too.
//

#include "Shared.xcconfig"

// MARK: - Environment
ENVIRONMENT_NAME = Local

// MARK: - API
// `$()` escape breaks the `//` token so xcconfig doesn't treat the rest as a comment.
API_BASE_URL = http:/$()/localhost:8002

// MARK: - Sentry
// Same DSN as Prod — events tagged with environment:local for filtering in Sentry UI.
// Enables crash/log capture from debug builds so /check-crashes can analyze dev issues.
SENTRY_DSN = https:/$()/c5440340d41535b4862af9385d9bc38c@o4511195958738944.ingest.de.sentry.io/4511196118188112

// MARK: - Identity
PRODUCT_BUNDLE_IDENTIFIER = $(BUNDLE_ID_BASE)
BUNDLE_DISPLAY_NAME = $(APP_DISPLAY_NAME) Local

// MARK: - Capabilities
CODE_SIGN_ENTITLEMENTS = Hangs/Hangs-Local.entitlements

// Signing lives in the build-type × env composition files (Debug-Local / Release-Local).
