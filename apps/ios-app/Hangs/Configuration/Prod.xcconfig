//
// Prod.xcconfig
// Environment-only settings for the production build (API → Fly.io, TestFlight/App Store).
// Include Shared here so any xcconfig that wants just Prod can pull the base too.
//

#include "Shared.xcconfig"

// MARK: - Environment
ENVIRONMENT_NAME = Production

// MARK: - API
// `$()` escape breaks the `//` token so xcconfig doesn't treat the rest as a comment.
API_BASE_URL = https:/$()/quiz-agent-api.fly.dev

// MARK: - Sentry
SENTRY_DSN = https:/$()/c5440340d41535b4862af9385d9bc38c@o4511195958738944.ingest.de.sentry.io/4511196118188112

// MARK: - Identity
PRODUCT_BUNDLE_IDENTIFIER = $(BUNDLE_ID_BASE)
BUNDLE_DISPLAY_NAME = $(APP_DISPLAY_NAME)

// MARK: - Capabilities
CODE_SIGN_ENTITLEMENTS = Hangs/Hangs-Prod.entitlements

// Signing lives in the build-type × env composition files (Debug-Prod / Release-Prod),
// because Debug needs a Development profile (installable on device) while Release-Prod
// needs the AppStore distribution profile used by fastlane match.
