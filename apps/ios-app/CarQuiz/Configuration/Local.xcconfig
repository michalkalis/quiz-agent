//
// Local.xcconfig
// CarQuiz
//
// Configuration for local development environment
//

#include "Shared.xcconfig"

// MARK: - Environment
ENVIRONMENT_NAME = Local

// MARK: - API Configuration
API_BASE_URL = http:/$()/localhost:8002

// MARK: - Sentry
// Same DSN as Prod — events tagged with environment:local for filtering in Sentry UI.
// Enables crash/log capture from debug builds so /check-crashes can analyze dev issues.
// `$()` escape breaks the `//` token so xcconfig doesn't treat the rest of the line as a comment.
SENTRY_DSN = https:/$()/c5440340d41535b4862af9385d9bc38c@o4511195958738944.ingest.de.sentry.io/4511196118188112

// MARK: - Bundle Identifier
// No suffix for local development
PRODUCT_BUNDLE_IDENTIFIER = $(BUNDLE_ID_BASE)

// MARK: - App Display Name
// Add environment indicator to app name
PRODUCT_NAME = $(APP_DISPLAY_NAME) Local

// MARK: - Debug Settings
ENABLE_TESTABILITY = YES
GCC_OPTIMIZATION_LEVEL = 0
SWIFT_OPTIMIZATION_LEVEL = -Onone
SWIFT_ACTIVE_COMPILATION_CONDITIONS = DEBUG
