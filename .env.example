# ── LLM Gateway (issue #53) ──────────────────────────────────────────────────
# All chat / embedding / verification / scoring calls flow through one factory
# (packages/shared/quiz_shared/llm/factory.py). LLM_GATEWAY chooses the route:
#   direct      = canonical provider endpoints (OpenAI / Gemini / Anthropic).
#                 Needs OPENAI_API_KEY (+ GOOGLE_API_KEY for Gemini verification,
#                 ANTHROPIC_API_KEY for the second scorer; absent → those degrade).
#   openrouter  = one key + one prepaid balance serves chat + embeddings + Gemini
#                 + Claude. Needs only OPENROUTER_API_KEY. This is the rollback
#                 lever: flip back to `direct` to bypass OpenRouter entirely.
# Audio (TTS / Whisper) and image (gpt-image-1) always stay on OpenAI directly —
# OpenRouter does not serve them — so OPENAI_API_KEY is required either way.
LLM_GATEWAY=direct

# OpenAI API Key — always required (audio/image direct, and `direct` gateway).
# Get your key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-your-openai-api-key-here

# OpenRouter API Key — required when LLM_GATEWAY=openrouter.
# Get your key from: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-api-key-here

# Google API Key (Gemini fact/logic verification under LLM_GATEWAY=direct only).
# Get your key from: https://aistudio.google.com/apikey
GOOGLE_API_KEY=your-google-api-key-here

# Anthropic API Key (second scorer under LLM_GATEWAY=direct only)
# Get your key from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here

# Tavily API Key (for web search)
# Get your key from: https://tavily.com/
TAVILY_API_KEY=tvly-your-tavily-api-key-here

# Cloudflare R2 (image storage for image-based questions)
# Set up at: https://dash.cloudflare.com → R2 Object Storage
R2_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET=quiz-images
R2_PUBLIC_URL=https://pub-<hash>.r2.dev

# ── quiz-pack-api Phase 1 (issue #33) ────────────────────────────────────────
# Postgres + pgvector. Local default points at apps/quiz-pack-api/docker-compose.yml.
# Prod = Fly Postgres `quiz-pack-db` (custom image registry.fly.io/quiz-pack-db:pgvector-0.8.2).
DATABASE_URL=postgresql+asyncpg://quiz:quiz@localhost:5432/quiz_pack
# Optional: separate test DB so pytest doesn't clobber dev data. Used in Task 1.3.
TEST_DATABASE_URL=postgresql+asyncpg://quiz:quiz@localhost:5432/quiz_pack_test

# Redis (ARQ queue + SSE pubsub). Local = docker-compose. Prod = Upstash (rediss://).
REDIS_URL=redis://localhost:6379/0
